.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 48rpx 32rpx;
}

.header {
  margin-bottom: 32rpx;
}

.title {
  display: block;
  color: #111827;
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.2;
}

.subtitle {
  display: block;
  margin-top: 16rpx;
  color: #64748b;
  font-size: 28rpx;
  line-height: 1.6;
}

.entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
  padding: 30rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
  background: #ffffff;
  text-decoration: none;
}

.entry-title,
.entry-copy {
  display: block;
}

.entry-title {
  color: #111827;
  font-size: 34rpx;
  font-weight: 700;
}

.entry-copy {
  margin-top: 8rpx;
  color: #64748b;
  font-size: 26rpx;
  line-height: 1.5;
}

.entry-arrow {
  color: #2563eb;
  font-size: 52rpx;
  line-height: 1;
}
