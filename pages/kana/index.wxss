.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 28rpx 28rpx 48rpx;
}

.topbar {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.eyebrow,
.title,
.score-main,
.score-sub,
.scope,
.progress,
.prompt-label,
.sound-mark,
.feedback text {
  display: block;
}

.eyebrow {
  color: #2563eb;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.2;
}

.title {
  margin-top: 6rpx;
  color: #111827;
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.2;
}

.score {
  min-width: 132rpx;
  box-sizing: border-box;
  padding: 14rpx 18rpx;
  border: 1rpx solid #dbeafe;
  border-radius: 8rpx;
  background: #eff6ff;
  text-align: right;
}

.score-main {
  display: inline;
  color: #1d4ed8;
  font-size: 34rpx;
  font-weight: 800;
}

.score-sub {
  display: inline;
  color: #64748b;
  font-size: 24rpx;
}

.mode-tabs {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8rpx;
  box-sizing: border-box;
  padding: 8rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
  background: #ffffff;
}

.mode-tab {
  min-height: 72rpx;
  border: 0;
  border-radius: 6rpx;
  background: transparent;
  color: #475569;
  font-size: 28rpx;
  line-height: 72rpx;
}

.mode-tab.is-active {
  background: #111827;
  color: #ffffff;
  font-weight: 700;
}

.qtype-tabs {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 8rpx;
  box-sizing: border-box;
  padding: 8rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
  background: #ffffff;
  margin-top: 14rpx;
}

.qtype-tab {
  min-height: 70rpx;
  border: 0;
  border-radius: 6rpx;
  background: transparent;
  color: #475569;
  font-size: 26rpx;
  line-height: 70rpx;
  text-align: center;
}

.qtype-tab.is-active {
  background: #111827;
  color: #ffffff;
  font-weight: 700;
}

.filter-scroll {
  width: 100%;
  margin: 20rpx 0 0;
  white-space: nowrap;
}

.filter-track {
  display: inline-flex;
  gap: 12rpx;
  padding-bottom: 2rpx;
}

.filter-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 112rpx;
  min-height: 64rpx;
  box-sizing: border-box;
  padding: 0 22rpx;
  border: 1rpx solid #cbd5e1;
  border-radius: 8rpx;
  background: #ffffff;
  color: #475569;
  font-size: 26rpx;
  line-height: 64rpx;
}

.filter-chip.is-active {
  border-color: #2563eb;
  background: #eff6ff;
  color: #1d4ed8;
  font-weight: 700;
}

.card {
  margin-top: 24rpx;
  box-sizing: border-box;
  padding: 26rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
  background: #ffffff;
}

.card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.scope {
  color: #111827;
  font-size: 28rpx;
  font-weight: 700;
}

.progress {
  color: #64748b;
  font-size: 24rpx;
}

.prompt {
  display: grid;
  grid-template-columns: 1fr 112rpx;
  grid-template-rows: auto auto;
  column-gap: 22rpx;
  align-items: center;
  min-height: 220rpx;
  margin-top: 26rpx;
  box-sizing: border-box;
  padding: 26rpx;
  border: 1rpx solid #dbeafe;
  border-radius: 8rpx;
  background: #f8fbff;
}

.prompt-label {
  color: #64748b;
  font-size: 24rpx;
  line-height: 1.2;
}

.sound-mark {
  margin-top: 8rpx;
  color: #111827;
  font-size: 86rpx;
  font-weight: 800;
  line-height: 1.1;
}

.audio-button {
  grid-column: 2;
  grid-row: 1 / 3;
  width: 112rpx;
  height: 112rpx;
  border: 0;
  border-radius: 56rpx;
  background: #2563eb;
  color: #ffffff;
  line-height: 112rpx;
}

.audio-button.is-pressing {
  background: #1d4ed8;
}

.audio-icon {
  display: block;
  padding-left: 6rpx;
  font-size: 38rpx;
  line-height: 112rpx;
}

.answer-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 24rpx;
}

.answer {
  min-height: 142rpx;
  border: 1rpx solid #cbd5e1;
  border-radius: 8rpx;
  background: #ffffff;
  color: #111827;
  line-height: 142rpx;
}

.answer[disabled] {
  color: #111827;
}

.answer-kana {
  display: block;
  font-size: 62rpx;
  font-weight: 800;
  line-height: 142rpx;
}

.answer.is-romaji .answer-kana {
  font-size: 44rpx;
}

.answer.is-correct {
  border-color: #16a34a;
  background: #dcfce7;
  color: #166534;
}

.answer.is-wrong {
  border-color: #dc2626;
  background: #fee2e2;
  color: #991b1b;
}

.feedback {
  min-height: 48rpx;
  margin-top: 20rpx;
  color: #64748b;
  font-size: 26rpx;
  line-height: 48rpx;
}

.feedback.correct {
  color: #166534;
}

.feedback.wrong {
  color: #991b1b;
}

.actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 18rpx;
}

.primary,
.secondary {
  min-height: 84rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  line-height: 84rpx;
}

.primary {
  border: 0;
  background: #111827;
  color: #ffffff;
}

.primary[disabled] {
  background: #cbd5e1;
  color: #ffffff;
}

.secondary {
  border: 1rpx solid #cbd5e1;
  background: #ffffff;
  color: #334155;
}

.kana-table {
  margin-top: 24rpx;
  box-sizing: border-box;
  padding: 16rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
  background: #ffffff;
}

.table-row {
  display: grid;
  grid-template-columns: 86rpx repeat(5, 1fr);
  gap: 6rpx;
  min-height: 58rpx;
  align-items: center;
}

.header-row {
  min-height: 46rpx;
}

.row-title,
.cell-title,
.cell {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 52rpx;
  border-radius: 6rpx;
  font-size: 24rpx;
}

.row-title,
.cell-title {
  color: #64748b;
}

.row-title {
  justify-content: flex-start;
  font-weight: 700;
}

.cell {
  background: #f8fafc;
  color: #111827;
  font-size: 30rpx;
  font-weight: 700;
}

.cell:empty {
  background: transparent;
}

.cell.is-current {
  background: #111827;
  color: #ffffff;
}
